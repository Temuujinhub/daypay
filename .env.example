# ─── API (apps/api) ───────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://daypay:daypay@localhost:5432/daypay?schema=public

# Redis (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Sandbox (DFSA ITL) limits
SANDBOX_MODE=true
SANDBOX_MAX_USERS=100

# ─── External integrations (use MOCK adapters until real keys arrive) ──
INTEGRATIONS_MODE=mock
# UAEID_API_URL=
# UAEID_API_KEY=
# AECB_API_URL=
# AECB_API_KEY=
# SMS_GATEWAY_URL=
# SMS_GATEWAY_KEY=

# ─── Web (apps/web) ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── Mobile (apps/mobile) ─────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000
