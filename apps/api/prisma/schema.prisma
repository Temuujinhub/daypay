// DayPay data model — translated from the System Specification §8 (Өгөгдлийн Сангийн Схем).
// Field names are camelCase (idiomatic Prisma) and mapped to the snake_case columns/tables
// described in the spec.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────
enum KycStatus {
  pending
  in_review
  verified
  rejected
}

enum UserRole {
  user
  lender_admin
  super_admin
  mlro
}

enum PreferredLanguage {
  en
  hi
  tl
  bn
  ur
}

enum AmlScreeningResult {
  clear
  flagged
  blocked
}

enum ApplicationStatus {
  draft
  submitted
  eligibility_check
  documents_pending
  under_review
  approved
  rejected
  cancelled
  disbursed
}

enum LoanStatus {
  active
  settled
  defaulted
  written_off
}

enum ScheduleStatus {
  pending
  paid
  partially_paid
  overdue
  waived
}

enum TransactionType {
  disbursement
  repayment
  early_settlement
  penalty
  refund
  remittance
}

enum TransactionDirection {
  credit
  debit
}

enum TransactionStatus {
  pending
  completed
  failed
  reversed
}

enum DocumentType {
  emirates_id_front
  emirates_id_back
  selfie
  salary_slip
  bank_statement
  employment_letter
  loan_agreement
  other
}

enum NotificationChannel {
  push
  sms
  email
}

enum ActorType {
  user
  admin
  lender
  system
}

// ─── Users & KYC ──────────────────────────────────────────────────────────
model User {
  id                String            @id @default(uuid()) @db.Uuid
  phoneNumber       String            @unique @map("phone_number") @db.VarChar(15)
  phoneVerified     Boolean           @default(false) @map("phone_verified")
  email             String?           @unique @db.VarChar(255)
  fullName          String?           @map("full_name") @db.VarChar(255)
  kycStatus         KycStatus         @default(pending) @map("kyc_status")
  creditScore       Int?              @map("credit_score")
  creditLimit       Decimal           @default(0) @map("credit_limit") @db.Decimal(12, 2)
  availableCredit   Decimal           @default(0) @map("available_credit") @db.Decimal(12, 2)
  preferredLanguage PreferredLanguage @default(en) @map("preferred_language")
  isActive          Boolean           @default(true) @map("is_active")
  isSandboxUser     Boolean           @default(false) @map("is_sandbox_user")
  role              UserRole          @default(user)
  lenderId          String?           @map("lender_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastLoginAt       DateTime?         @map("last_login_at") @db.Timestamptz(6)

  kycProfile    KycProfile?
  applications  LoanApplication[]
  loans         Loan[]
  transactions  Transaction[]
  notifications Notification[]
  documents     Document[]

  @@index([phoneNumber])
  @@index([kycStatus])
  @@map("users")
}

model KycProfile {
  id                  String              @id @default(uuid()) @db.Uuid
  userId              String              @unique @map("user_id") @db.Uuid
  emiratesIdNumber    String?             @unique @map("emirates_id_number") @db.VarChar(20)
  emiratesIdFrontS3   String?             @map("emirates_id_front_s3") @db.VarChar(500)
  emiratesIdBackS3    String?             @map("emirates_id_back_s3") @db.VarChar(500)
  selfieS3            String?             @map("selfie_s3") @db.VarChar(500)
  fullNameEn          String?             @map("full_name_en") @db.VarChar(255)
  fullNameAr          String?             @map("full_name_ar") @db.VarChar(255)
  nationality         String?             @db.VarChar(3)
  gender              String?             @db.VarChar(10)
  dateOfBirth         DateTime?           @map("date_of_birth") @db.Date
  emiratesIdExpiry    DateTime?           @map("emirates_id_expiry") @db.Date
  addressArea         String?             @map("address_area") @db.VarChar(100)
  addressCity         String?             @map("address_city") @db.VarChar(50)
  uaeidApiResponse    Json?               @map("uaeid_api_response")
  biometricMatchScore Decimal?            @map("biometric_match_score") @db.Decimal(5, 2)
  amlScreeningResult  AmlScreeningResult  @default(clear) @map("aml_screening_result")
  amlScreeningDate    DateTime?           @map("aml_screening_date") @db.Timestamptz(6)
  reviewedBy          String?             @map("reviewed_by") @db.Uuid
  reviewedAt          DateTime?           @map("reviewed_at") @db.Timestamptz(6)
  reviewNotes         String?             @map("review_notes")
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_profiles")
}

// ─── Loan products & lenders ──────────────────────────────────────────────
model LoanProduct {
  id             String   @id @default(uuid()) @db.Uuid
  productCode    String   @unique @map("product_code") @db.VarChar(50)
  nameEn         String   @map("name_en") @db.VarChar(255)
  nameHi         String?  @map("name_hi") @db.VarChar(255)
  nameTl         String?  @map("name_tl") @db.VarChar(255)
  nameBn         String?  @map("name_bn") @db.VarChar(255)
  nameUr         String?  @map("name_ur") @db.VarChar(255)
  descriptionEn  String?  @map("description_en")
  baseApr        Decimal  @map("base_apr") @db.Decimal(5, 2)
  maxAmount      Decimal  @map("max_amount") @db.Decimal(12, 2)
  minAmount      Decimal  @default(1000) @map("min_amount") @db.Decimal(12, 2)
  availableTerms Int[]    @map("available_terms")
  minCreditScore Int      @default(600) @map("min_credit_score")
  minAge         Int      @default(21) @map("min_age")
  maxAge         Int      @default(65) @map("max_age")
  isActive       Boolean  @default(true) @map("is_active")
  displayOrder   Int      @default(0) @map("display_order")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  lenderProducts LenderProduct[]
  applications   LoanApplication[]

  @@map("loan_products")
}

model Lender {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @db.VarChar(255)
  nameShort        String?   @map("name_short") @db.VarChar(50)
  cbuaeLicenceNo   String    @unique @map("cbuae_licence_no") @db.VarChar(50)
  licenceVerified  Boolean   @default(false) @map("licence_verified")
  licenceExpiry    DateTime? @map("licence_expiry") @db.Date
  contactEmail     String?   @map("contact_email") @db.VarChar(255)
  apiEndpoint      String?   @map("api_endpoint") @db.VarChar(500)
  apiKeyEncrypted  String?   @map("api_key_encrypted")
  logoUrl          String?   @map("logo_url") @db.VarChar(500)
  rating           Decimal   @default(0) @db.Decimal(3, 1)
  isActive         Boolean   @default(true) @map("is_active")
  isSandboxEnabled Boolean   @default(false) @map("is_sandbox_enabled")
  onboardedAt      DateTime? @map("onboarded_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  products     LenderProduct[]
  applications LoanApplication[]
  loans        Loan[]

  @@map("lenders")
}

model LenderProduct {
  id                 String   @id @default(uuid()) @db.Uuid
  lenderId           String   @map("lender_id") @db.Uuid
  loanProductId      String   @map("loan_product_id") @db.Uuid
  offeredApr         Decimal  @map("offered_apr") @db.Decimal(5, 2)
  maxAmount          Decimal  @map("max_amount") @db.Decimal(12, 2)
  minAmount          Decimal  @map("min_amount") @db.Decimal(12, 2)
  availableTerms     Int[]    @map("available_terms")
  minCreditScore     Int      @default(600) @map("min_credit_score")
  maxDtiRatio        Decimal  @default(0.50) @map("max_dti_ratio") @db.Decimal(4, 2)
  earlySettlementFee Decimal  @default(0.01) @map("early_settlement_fee") @db.Decimal(4, 2)
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  lender       Lender            @relation(fields: [lenderId], references: [id])
  loanProduct  LoanProduct       @relation(fields: [loanProductId], references: [id])
  applications LoanApplication[]

  @@unique([lenderId, loanProductId])
  @@map("lender_products")
}

// ─── Applications, loans, schedules ───────────────────────────────────────
model LoanApplication {
  id                String            @id @default(uuid()) @db.Uuid
  applicationNumber String            @unique @map("application_number") @db.VarChar(20)
  userId            String            @map("user_id") @db.Uuid
  lenderProductId   String            @map("lender_product_id") @db.Uuid
  loanProductId     String            @map("loan_product_id") @db.Uuid
  lenderId          String            @map("lender_id") @db.Uuid
  requestedAmount   Decimal           @map("requested_amount") @db.Decimal(12, 2)
  requestedTerm     Int               @map("requested_term")
  purpose           String?           @db.VarChar(100)
  status            ApplicationStatus @default(draft)
  rejectionReason   String?           @map("rejection_reason")
  approvedAmount    Decimal?          @map("approved_amount") @db.Decimal(12, 2)
  approvedApr       Decimal?          @map("approved_apr") @db.Decimal(5, 2)
  approvedTerm      Int?              @map("approved_term")
  eligibilityPassed Boolean?          @map("eligibility_passed")
  creditScoreAtApp  Int?              @map("credit_score_at_app")
  esignCompletedAt  DateTime?         @map("esign_completed_at") @db.Timestamptz(6)
  esignIpAddress    String?           @map("esign_ip_address") @db.Inet
  submittedAt       DateTime?         @map("submitted_at") @db.Timestamptz(6)
  decidedAt         DateTime?         @map("decided_at") @db.Timestamptz(6)
  decidedBy         String?           @map("decided_by") @db.Uuid
  sandboxFlag       Boolean           @default(false) @map("sandbox_flag")
  metadata          Json?
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  user          User          @relation(fields: [userId], references: [id])
  lenderProduct LenderProduct @relation(fields: [lenderProductId], references: [id])
  loanProduct   LoanProduct   @relation(fields: [loanProductId], references: [id])
  lender        Lender        @relation(fields: [lenderId], references: [id])
  loan          Loan?
  documents     Document[]

  @@index([userId])
  @@index([status])
  @@index([lenderId])
  @@map("loan_applications")
}

model Loan {
  id                    String     @id @default(uuid()) @db.Uuid
  loanNumber            String     @unique @map("loan_number") @db.VarChar(20)
  applicationId         String     @unique @map("application_id") @db.Uuid
  userId                String     @map("user_id") @db.Uuid
  lenderId              String     @map("lender_id") @db.Uuid
  principalAmount       Decimal    @map("principal_amount") @db.Decimal(12, 2)
  apr                   Decimal    @db.Decimal(5, 2)
  termMonths            Int        @map("term_months")
  monthlyPayment        Decimal    @map("monthly_payment") @db.Decimal(12, 2)
  outstandingBalance    Decimal    @map("outstanding_balance") @db.Decimal(12, 2)
  totalPaid             Decimal    @default(0) @map("total_paid") @db.Decimal(12, 2)
  totalInterestPaid     Decimal    @default(0) @map("total_interest_paid") @db.Decimal(12, 2)
  disbursedAt           DateTime?  @map("disbursed_at") @db.Timestamptz(6)
  nextPaymentDate       DateTime?  @map("next_payment_date") @db.Date
  nextPaymentAmount     Decimal?   @map("next_payment_amount") @db.Decimal(12, 2)
  paymentsMade          Int        @default(0) @map("payments_made")
  paymentsRemaining     Int        @map("payments_remaining")
  status                LoanStatus @default(active)
  earlySettlementDate   DateTime?  @map("early_settlement_date") @db.Date
  earlySettlementAmount Decimal?   @map("early_settlement_amount") @db.Decimal(12, 2)
  sandboxFlag           Boolean    @default(false) @map("sandbox_flag")
  createdAt             DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  application  LoanApplication     @relation(fields: [applicationId], references: [id])
  user         User                @relation(fields: [userId], references: [id])
  lender       Lender              @relation(fields: [lenderId], references: [id])
  schedules    RepaymentSchedule[]
  transactions Transaction[]

  @@index([userId])
  @@index([status])
  @@map("loans")
}

model RepaymentSchedule {
  id                 String         @id @default(uuid()) @db.Uuid
  loanId             String         @map("loan_id") @db.Uuid
  installmentNumber  Int            @map("installment_number")
  dueDate            DateTime       @map("due_date") @db.Date
  principalComponent Decimal        @map("principal_component") @db.Decimal(12, 2)
  interestComponent  Decimal        @map("interest_component") @db.Decimal(12, 2)
  totalAmount        Decimal        @map("total_amount") @db.Decimal(12, 2)
  paidAmount         Decimal        @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paidAt             DateTime?      @map("paid_at") @db.Timestamptz(6)
  status             ScheduleStatus @default(pending)
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  loan         Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([loanId, installmentNumber])
  @@index([dueDate, status])
  @@map("repayment_schedules")
}

model Transaction {
  id              String               @id @default(uuid()) @db.Uuid
  referenceNumber String               @unique @map("reference_number") @db.VarChar(30)
  userId          String               @map("user_id") @db.Uuid
  loanId          String?              @map("loan_id") @db.Uuid
  scheduleId      String?              @map("schedule_id") @db.Uuid
  type            TransactionType
  amount          Decimal              @db.Decimal(12, 2)
  currency        String               @default("AED") @db.Char(3)
  direction       TransactionDirection
  status          TransactionStatus    @default(pending)
  paymentMethod   String?              @map("payment_method") @db.VarChar(30)
  ibanLast4       String?              @map("iban_last4") @db.VarChar(4)
  bankReference   String?              @map("bank_reference") @db.VarChar(100)
  processedAt     DateTime?            @map("processed_at") @db.Timestamptz(6)
  failureReason   String?              @map("failure_reason")
  metadata        Json?
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  user     User               @relation(fields: [userId], references: [id])
  loan     Loan?              @relation(fields: [loanId], references: [id])
  schedule RepaymentSchedule? @relation(fields: [scheduleId], references: [id])

  @@index([userId])
  @@index([loanId])
  @@index([createdAt(sort: Desc)])
  @@map("transactions")
}

model Document {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  applicationId  String?      @map("application_id") @db.Uuid
  documentType   DocumentType @map("document_type")
  s3Key          String       @map("s3_key") @db.VarChar(500)
  s3Bucket       String       @map("s3_bucket") @db.VarChar(100)
  fileName       String?      @map("file_name") @db.VarChar(255)
  fileSize       Int?         @map("file_size")
  mimeType       String?      @map("mime_type") @db.VarChar(100)
  isVerified     Boolean      @default(false) @map("is_verified")
  verifiedBy     String?      @map("verified_by") @db.Uuid
  verifiedAt     DateTime?    @map("verified_at") @db.Timestamptz(6)
  retentionUntil DateTime?    @map("retention_until") @db.Date
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  user        User             @relation(fields: [userId], references: [id])
  application LoanApplication? @relation(fields: [applicationId], references: [id])

  @@map("documents")
}

model Notification {
  id       String              @id @default(uuid()) @db.Uuid
  userId   String              @map("user_id") @db.Uuid
  type     String              @db.VarChar(50)
  channel  NotificationChannel
  title    String?
  body     String
  isRead   Boolean             @default(false) @map("is_read")
  sentAt   DateTime?           @map("sent_at") @db.Timestamptz(6)
  readAt   DateTime?           @map("read_at") @db.Timestamptz(6)
  metadata Json?
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id          String     @id @default(uuid()) @db.Uuid
  actorId     String?    @map("actor_id") @db.Uuid
  actorType   ActorType? @map("actor_type")
  action      String     @db.VarChar(100)
  entityType  String?    @map("entity_type") @db.VarChar(50)
  entityId    String?    @map("entity_id") @db.Uuid
  oldValues   Json?      @map("old_values")
  newValues   Json?      @map("new_values")
  ipAddress   String?    @map("ip_address") @db.Inet
  userAgent   String?    @map("user_agent")
  requestId   String?    @map("request_id") @db.Uuid
  sandboxFlag Boolean    @default(false) @map("sandbox_flag")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityType, entityId])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ─── DFSA ITL sandbox configuration (§10.2) ───────────────────────────────
model SandboxConfig {
  key         String   @id @db.VarChar(100)
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("sandbox_config")
}
